# Copy to .env and fill in only the providers you use. Never commit .env.
# LiteLLM reads these standard names automatically.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...      # the diverse open-model basket (DeepSeek, Qwen, Llama...)
# GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...

# Ollama needs no key. Override the host if not the default:
# OLLAMA_API_BASE=http://localhost:11434
